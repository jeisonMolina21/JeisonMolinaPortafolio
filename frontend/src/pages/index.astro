---
import Layout from '../layouts/MainLayout.astro';
import Navbar from '../components/modern/Navbar';
import Hero from '../components/modern/Hero';
import About from '../components/modern/About';
import Skills from '../components/modern/Skills';
import Projects from '../components/modern/Projects';
import Experience from '../components/modern/Experience';
import Education from '../components/modern/Education';
import Recognitions from '../components/modern/Recognitions';
import Contact from '../components/modern/Contact';
import Footer from '../components/modern/Footer';
import { profileService } from '../services/apiService';

let summaryData = null;
try {
  summaryData = await profileService.getSummary('es');
} catch (error) {
  console.error("Error fetching summary data:", error);
}

const { profile, skills, education, recognitions } = summaryData || {};
---

<Layout title="Jeison Molina | Full-Stack Developer & Automation Specialist">
	<main class="bg-slate-950 selection:bg-primary/30 selection:text-white relative">
		
		<!-- Scroll Progress Bar -->
		<div id="scroll-progress" class="fixed top-0 left-0 h-[2px] bg-gradient-to-r from-primary to-secondary z-[100] transition-all duration-75 ease-out"></div>

		<!-- Custom Cursor (desktop only) -->
		<div id="custom-cursor" class="hidden lg:block fixed w-6 h-6 border border-primary/40 rounded-full pointer-events-none z-[9999] mix-blend-difference transition-transform duration-200 ease-out"></div>

		<Navbar client:load />
		
		<div class="space-y-0">
			<Hero client:load profile={profile} />
			<About client:visible />
			<Skills client:visible skills={skills || []} />
			<Projects client:visible />
			<Experience client:visible />
			<Education client:visible education={education || []} />
			<Recognitions client:visible recognitions={recognitions || []} />
			<Contact client:visible profile={profile} />
		</div>

		<Footer client:load />
	</main>
</Layout>

<script>
	// Scroll Progress
	window.addEventListener('scroll', () => {
		const bar = document.getElementById('scroll-progress');
		if (!bar) return;
		const total = document.documentElement.scrollHeight - window.innerHeight;
		const progress = (window.scrollY / total) * 100;
		bar.style.width = `${progress}%`;
	});

	// Custom Cursor
	const cursor = document.getElementById('custom-cursor');
	if (cursor) {
		window.addEventListener('mousemove', (e) => {
			cursor.style.transform = `translate(${e.clientX - 12}px, ${e.clientY - 12}px)`;
		});
	}

	// Reveal Animations
	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('reveal-active');
			}
		});
	}, { threshold: 0.1 });

	document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

<style is:global>
	html {
		scroll-behavior: smooth;
		cursor: none;
	}

	@media (max-width: 1024px) {
		html {
			cursor: auto;
		}
	}

	::-webkit-scrollbar {
		width: 6px;
	}

	::-webkit-scrollbar-track {
		background: #020617;
	}

	::-webkit-scrollbar-thumb {
		background: #1e293b;
		border-radius: 5px;
	}

	::-webkit-scrollbar-thumb:hover {
		background: #0ea5e9;
	}

	body {
		overflow-x: hidden;
		width: 100vw;
	}
</style>
