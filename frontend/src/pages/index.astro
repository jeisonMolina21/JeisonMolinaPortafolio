---
import Layout from '../layouts/MainLayout.astro';
import Navbar from '../components/modern/Navbar';
import Hero from '../components/modern/Hero';
import About from '../components/modern/About';
import Projects from '../components/modern/Projects';
import Experience from '../components/modern/Experience';
import SocialProof from '../components/modern/SocialProof';
import Contact from '../components/modern/Contact';
import Footer from '../components/modern/Footer';
import { profileService } from '../services/apiService';

let summaryData = null;
try {
  summaryData = await profileService.getSummary('es');
} catch (error) {
  console.error("Error fetching summary data:", error);
}

const { profile, experience, projects } = summaryData || {};
---

<Layout title="Jeison Molina | Full-Stack Developer & Automation Specialist">
	<script is:inline>
		const theme = (() => {
			if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
				return localStorage.getItem('theme');
			}
			return 'dark';
		})();
		if (theme === 'light') {
			document.documentElement.classList.add('light');
		} else {
			document.documentElement.classList.remove('light');
		}
	</script>

	<main class="bg-slate-950 selection:bg-primary/30 selection:text-white relative">
		
		<!-- Scroll Progress Bar -->
		<div id="scroll-progress" class="fixed top-0 left-0 h-[2px] bg-gradient-to-r from-primary to-secondary z-[100] transition-all duration-75 ease-out"></div>

		<!-- Custom Cursor -->
		<div id="custom-cursor" class="hidden lg:block fixed pointer-events-none z-[9999] mix-blend-difference transition-transform duration-100 ease-out">
			<div class="w-8 h-8 border border-primary rounded-full flex items-center justify-center">
				<div class="w-1 h-1 bg-primary rounded-full"></div>
			</div>
		</div>

		<Navbar client:load />
		
		<div class="space-y-0">
			<Hero client:load profile={profile} />
			<About client:visible />
			<Projects client:visible projects={projects} />
			<Experience client:visible experiences={experience} />
			<SocialProof client:visible />
			<Contact client:visible profile={profile} />
		</div>

		<Footer client:load />
	</main>
</Layout>

<script>
	// Scroll Progress
	window.addEventListener('scroll', () => {
		const bar = document.getElementById('scroll-progress');
		if (!bar) return;
		const total = document.documentElement.scrollHeight - window.innerHeight;
		const progress = (window.scrollY / total) * 100;
		bar.style.width = `${progress}%`;
	});

	// Custom Cursor
	const cursor = document.getElementById('custom-cursor');
	if (cursor) {
		window.addEventListener('mousemove', (e) => {
			cursor.style.left = `${e.clientX}px`;
			cursor.style.top = `${e.clientY}px`;
			cursor.style.transform = `translate(-50%, -50%)`;
		});

		// Hover effects
		const links = document.querySelectorAll('a, button, [role="button"]');
		links.forEach(link => {
			link.addEventListener('mouseenter', () => {
				cursor.style.transform = `translate(-50%, -50%) scale(2)`;
				cursor.style.borderColor = 'rgba(255, 255, 255, 0.8)';
			});
			link.addEventListener('mouseleave', () => {
				cursor.style.transform = `translate(-50%, -50%) scale(1)`;
				cursor.style.borderColor = 'var(--color-primary)';
			});
		});
	}

	// Reveal Animations
	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('reveal-active');
			}
		});
	}, { threshold: 0.1 });

	document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

<style is:global>
	:root {
		--color-primary: #991b1b; /* Crimson fallback if not in global.css */
	}

	html {
		scroll-behavior: smooth;
	}

	/* Only hide cursor on desktop to use the custom one */
	@media (min-width: 1024px) {
		html, body, a, button {
			cursor: none !important;
		}
	}

	@media (max-width: 1024px) {
		#custom-cursor {
			display: none !important;
		}
	}

	::-webkit-scrollbar {
		width: 6px;
	}

	::-webkit-scrollbar-track {
		background: #000000;
	}

	::-webkit-scrollbar-thumb {
		background: #4a0404;
		border-radius: 5px;
	}

	::-webkit-scrollbar-thumb:hover {
		background: #991b1b;
	}

	body {
		overflow-x: hidden;
		width: 100vw;
		background-color: black;
	}
</style>
