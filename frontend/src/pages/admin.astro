---
import MainLayout from '../layouts/MainLayout.astro';
import AdminDashboard from '../components/admin/AdminDashboard';
import { useAuthStore } from '../store/useAuthStore';
import { LayoutDashboard, LogOut, Settings, Briefcase, GraduationCap, Code } from 'lucide-react';
---

<MainLayout title="Admin Dashboard | Jeison Molina">
  <div class="min-h-screen bg-bg-deep flex">
    {/* Sidebar */}
    <aside class="w-64 bg-white dark:bg-midnight border-r border-primary/10 p-8 flex flex-col fixed h-full">
      <div class="mb-12">
        <p class="text-xs font-black uppercase tracking-[0.3em] text-primary">Sistema Admin</p>
        <p class="text-2xl font-black text-text-main">Jeison <span class="text-primary italic">M.</span></p>
      </div>

      <nav class="flex-1 space-y-4">
        {[
          { icon: <LayoutDashboard size={20} />, label: 'Resumen', active: true },
          { icon: <Briefcase size={20} />, label: 'Experiencia' },
          { icon: <Code size={20} />, label: 'Proyectos' },
          { icon: <GraduationCap size={20} />, label: 'Educación' },
          { icon: <Settings size={20} />, label: 'Ajustes' },
        ].map(item => (
          <button class={`w-full flex items-center gap-4 p-4 rounded-2xl font-bold transition-all ${item.active ? 'bg-primary text-white shadow-lg shadow-primary/20' : 'text-text-muted hover:bg-primary/5 hover:text-primary'}`}>
            {item.icon}
            {item.label}
          </button>
        ))}
      </nav>

      <button id="logout-btn-root" class="mt-auto flex items-center gap-4 p-4 text-red-500 font-bold hover:bg-red-500/5 rounded-2xl transition-all">
        <LogOut size={20} />
        Cerrar Sesión
      </button>
    </aside>

    {/* Main Content */}
    <main class="flex-1 ml-64 p-12 overflow-y-auto">
      <header class="flex justify-between items-center mb-12">
        <h1 class="text-4xl font-black text-text-main tracking-tighter">Panel de <span class="text-primary">Control</span></h1>
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-black">JM</div>
        </div>
      </header>

      <AdminDashboard client:only="react" />
    </main>
  </div>

  <script>
    import { useAuthStore } from '../store/useAuthStore';
    
    // Protection & Logout Logic
    const checkAuth = () => {
      const { isAdmin } = useAuthStore.getState();
      if (!isAdmin && window.location.pathname === '/admin') {
        window.location.href = '/';
      }
    };

    // Run check
    checkAuth();

    // Logout listener
    document.getElementById('logout-btn-root')?.addEventListener('click', () => {
      useAuthStore.getState().logout();
      window.location.href = '/';
    });
  </script>
</MainLayout>
</MainLayout>
