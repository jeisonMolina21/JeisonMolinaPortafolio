---
import { Github, ExternalLink, Code, ArrowRight, Layers, Cpu, Globe } from 'lucide-react';

interface Props {
  projects: any[];
}

const { projects } = Astro.props;
---

<section id="projects" class="section-padding bg-midnight relative overflow-hidden">
  <!-- Decorative background element -->
  <div class="absolute top-0 right-0 w-1/3 h-1/3 bg-primary/5 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="container-custom relative z-10">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-20 gap-8">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary/10 rounded-lg mb-6">
          <Layers size={14} class="text-primary" />
          <span class="text-[10px] font-bold uppercase tracking-widest text-primary">Portafolio</span>
        </div>
        <h2 class="text-4xl md:text-6xl font-display font-bold text-text-main leading-tight">
          Soluciones de Ingeniería que <span class="text-primary">generan valor</span>
        </h2>
      </div>
      <p class="text-text-dim max-w-sm text-sm leading-relaxed">
        Una selección de proyectos donde la arquitectura de software y la eficiencia operativa se encuentran.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      {projects.map((project) => (
        <div class="group relative flex flex-col bg-bg-surface border border-white/5 rounded-[2.5rem] overflow-hidden hover:border-primary/30 transition-all duration-500 hover:-translate-y-2">
          <!-- Image container -->
          <div class="relative aspect-[16/9] overflow-hidden">
            <img 
              src={project.image_url || 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&q=80'} 
              alt={project.title} 
              class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-midnight/90 via-midnight/20 to-transparent opacity-80"></div>
            
            <!-- Tech Badges on Image -->
            <div class="absolute bottom-6 left-6 flex flex-wrap gap-2">
              {project.technologies?.split(',').slice(0, 3).map((tech: string) => (
                <span class="px-3 py-1 bg-white/10 backdrop-blur-md border border-white/10 rounded-lg text-[10px] font-bold text-white uppercase tracking-wider">
                  {tech.trim()}
                </span>
              ))}
            </div>
          </div>

          <!-- Content -->
          <div class="p-8 md:p-10 flex flex-col flex-grow">
            <div class="flex items-start justify-between mb-6">
              <h3 class="text-2xl md:text-3xl font-display font-bold text-text-main group-hover:text-primary transition-colors">
                {project.title}
              </h3>
              <div class="flex gap-3">
                {project.github_url && (
                  <a href={project.github_url} target="_blank" class="p-2 bg-white/5 hover:bg-primary/20 rounded-xl text-text-dim hover:text-primary transition-all" aria-label="GitHub">
                    <Github size={20} />
                  </a>
                )}
                {project.demo_url && (
                  <a href={project.demo_url} target="_blank" class="p-2 bg-white/5 hover:bg-primary/20 rounded-xl text-text-dim hover:text-primary transition-all" aria-label="Demo">
                    <ExternalLink size={20} />
                  </a>
                )}
              </div>
            </div>
            
            <p class="text-text-dim text-sm leading-relaxed mb-8 line-clamp-3">
              {project.challenge || project.description}
            </p>

            <div class="mt-auto pt-8 border-t border-white/5 flex items-center justify-between">
              <div class="flex items-center gap-2 text-xs font-bold text-primary uppercase tracking-widest">
                <Cpu size={16} />
                <span>Backend Focused</span>
              </div>
              <a 
                href={`/proyectos/${project.title.toLowerCase().split(':')[0].trim().replace(/\s+/g, '-')}`} 
                class="flex items-center gap-2 text-xs font-bold text-text-main hover:text-primary transition-colors"
              >
                Ver Caso de Estudio
                <ArrowRight size={16} />
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
