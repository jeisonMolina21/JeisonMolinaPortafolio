---
import { Image } from 'astro:assets';
import fotoJeison from '../assets/jeison.png';
import { Github, Linkedin, ArrowRight, Zap, Clock, Sparkles } from 'lucide-react';
import DownloadCV from './DownloadCV';

interface Props {
  profile: any;
  experience: any[];
  education: any[];
  groupedSkills: any;
}

const { profile, experience, education, groupedSkills } = Astro.props;
const firstName = profile?.full_name?.split(' ')[0] || 'Jeison';
const lastName = profile?.full_name?.split(' ').slice(1).join(' ') || 'Molina';
---

<section id="hero" class="hero-section relative overflow-hidden bg-bg-deep transition-colors duration-500 min-h-[90vh] flex items-center">
  <!-- Subtle Background Pattern -->
  <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.05] pointer-events-none" style="background-image: radial-gradient(var(--color-primary) 0.5px, transparent 0.5px); background-size: 24px 24px;"></div>
  
  <div class="hero-background-cinematic">
    <div class="hero-glow-top"></div>
    <div class="hero-glow-bottom"></div>
  </div>

  <div class="container-custom relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      
      <!-- Text Content (Column 1) -->
      <div class="lg:col-span-7 space-y-6">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20">
            <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
            </span>
            <span class="text-[10px] font-black tracking-widest text-primary uppercase">DISPONIBLE — HIGH PERFORMANCE SOFTWARE</span>
        </div>
        
        <h1 class="text-6xl md:text-8xl font-black text-text-main leading-none tracking-tighter">
            Full Stack <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-primary-bright">Developer</span>
        </h1>

        <h2 class="text-2xl md:text-3xl font-bold text-text-muted italic flex items-center gap-3">
            Jeison Molina 
            <span class="h-px w-12 bg-primary/30"></span>
            <span class="text-primary not-italic text-xl uppercase tracking-widest font-black">Python, Node.js & React</span>
        </h2>

        <p class="text-xl text-text-muted leading-relaxed max-w-xl">
            Lidero el ciclo completo de desarrollo: desde el <span class="text-text-main font-bold">diseño de DB</span> y <span class="text-primary font-black">APIs robustas</span>, hasta interfaces modernas que procesan +50k datos/día.
        </p>

        <div class="flex flex-wrap gap-4 pt-4">
            <a href="#projects" class="px-8 py-4 bg-transparent border-2 border-primary text-primary font-bold rounded-2xl hover:bg-primary/5 transition-all flex items-center gap-2 group">
                Ver casos de éxito
                <span class="group-hover:translate-x-1 transition-transform">→</span>
            </a>
            <DownloadCV data={{ profile, experience, education, skills: groupedSkills ? Object.values(groupedSkills).flat() : [] }} client:load />
        </div>

        <div class="pt-8 flex items-center gap-6 text-xs font-black uppercase tracking-widest text-text-muted opacity-50">
            <span>🌎 Open to Remote LATAM/US</span>
            <span class="h-1 w-1 bg-text-muted rounded-full"></span>
            <span>Core Architect: Escalabilidad & Eficiencia</span>
        </div>
      </div>

      <!-- Image / Illustration (Column 2) -->
      <div class="lg:col-span-5 relative hidden lg:flex justify-end">
        <div class="relative w-full max-w-[420px]">
          <div class="absolute inset-0 bg-primary/10 blur-[100px] rounded-full"></div>
          
          <div class="relative aspect-[4/5] bg-bg-surface rounded-[2.5rem] overflow-hidden border border-primary/10 shadow-2xl">
            <Image 
              src={profile?.image_url || fotoJeison} 
              alt="Jeison Molina" 
              width={420}
              height={525}
              loading="eager"
              class="w-full h-full object-cover grayscale brightness-95 hover:grayscale-0 hover:brightness-105 transition-all duration-700"
            />
            
            <!-- Dynamic Floating Info -->
            <div class="absolute bottom-4 left-4 right-4 p-5 glass rounded-3xl border-white/10">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center text-white">
                  <Sparkles size={20} />
                </div>
                <div>
                  <p class="text-[9px] font-black uppercase tracking-[0.2em] text-primary mb-0.5">Core Architect</p>
                  <p class="text-text-main font-bold text-xs">Escalabilidad & Eficiencia</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-section {
    padding-top: 4rem;
  }
  .hero-background-cinematic {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .hero-glow-top {
    position: absolute;
    top: -10%;
    right: -5%;
    width: 40%;
    height: 40%;
    background: radial-gradient(circle, var(--color-primary-glow) 0%, transparent 70%);
    opacity: 0.3;
  }
</style>
