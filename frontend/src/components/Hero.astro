---
import { Image } from 'astro:assets';
import fotoJeison from '../assets/jeison.png';
import { Github, Linkedin, ArrowRight, Zap, Clock, Sparkles, Code2, Database, Terminal } from 'lucide-react';
import DownloadCV from './DownloadCV';

interface Props {
  profile: any;
  experience: any[];
  education: any[];
  groupedSkills: any;
}

const { profile, experience, education, groupedSkills } = Astro.props;

// Flatten skills for the quick stack view
const quickSkills = groupedSkills ? [
  ...groupedSkills['Backend & Data']?.slice(0, 3) || [],
  ...groupedSkills['Frontend']?.slice(0, 3) || [],
  ...groupedSkills['DevOps & Cloud']?.slice(0, 2) || []
] : [];
---

<section id="hero" class="relative min-h-screen flex items-center pt-20 pb-12 overflow-hidden bg-midnight transition-colors duration-500">
  <!-- Premium Background Effects -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-primary/10 blur-[120px] rounded-full animate-pulse-slow"></div>
    <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-primary-bright/5 blur-[100px] rounded-full"></div>
    <!-- Noise texture could go here if available -->
    <div class="absolute inset-0 opacity-[0.02] dark:opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 200 200\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noiseFilter\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.65\' numOctaves=\'3\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noiseFilter)\'/%3E%3C/svg%3E');"></div>
  </div>

  <div class="container-custom relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
      
      <!-- Content Column -->
      <div class="lg:col-span-7 space-y-8">
        <div class="space-y-4">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/5 border border-primary/10 animate-fade-in">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
            </span>
            <span class="text-[10px] font-bold tracking-[0.2em] text-primary uppercase">Disponible para nuevos desafíos</span>
          </div>

          <h1 class="text-5xl md:text-7xl lg:text-8xl font-display font-bold text-text-main leading-[1.1] tracking-tight animate-reveal-up">
            Arquitecto de <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-primary-bright to-primary">Soluciones Digitales</span>
          </h1>

          <p class="text-lg md:text-xl text-text-dim max-w-2xl leading-relaxed animate-fade-in-slow">
            Especializado en <span class="text-text-main font-semibold">automatización de alto impacto</span> y arquitecturas escalables. Transformo procesos complejos en sistemas eficientes que impulsan el crecimiento.
          </p>
        </div>

        <div class="flex flex-wrap gap-4 pt-4 animate-fade-in-slow">
          <a href="#projects" class="px-8 py-4 bg-primary text-white font-bold rounded-2xl hover:shadow-[0_0_20px_rgba(37,99,235,0.4)] hover:-translate-y-1 transition-all duration-300 flex items-center gap-2 group">
            Ver Proyectos
            <ArrowRight size={18} class="group-hover:translate-x-1 transition-transform" />
          </a>
          <DownloadCV data={{ profile, experience, education, skills: groupedSkills ? Object.values(groupedSkills).flat() : [] }} client:load />
        </div>

        <!-- Visible Tech Stack -->
        <div class="pt-12 space-y-4 animate-fade-in-slow">
          <p class="text-xs font-bold uppercase tracking-[0.3em] text-text-muted">Tech Stack Core</p>
          <div class="flex flex-wrap gap-3">
            {quickSkills.map((skill: any) => (
              <div class="flex items-center gap-2 px-4 py-2 bg-bg-surface border border-white/5 rounded-xl hover:border-primary/30 transition-colors group">
                <span class="text-sm font-medium text-text-dim group-hover:text-primary transition-colors">{skill.name}</span>
              </div>
            ))}
            <div class="px-4 py-2 border border-dashed border-white/10 rounded-xl flex items-center text-xs text-text-muted font-bold">
              +15 herramientas
            </div>
          </div>
        </div>
      </div>

      <!-- Visual Column -->
      <div class="lg:col-span-5 relative hidden lg:block animate-reveal-in">
        <div class="relative group">
          <!-- Background Glow -->
          <div class="absolute -inset-4 bg-gradient-to-br from-primary/20 to-transparent blur-3xl opacity-50 group-hover:opacity-75 transition-opacity"></div>
          
          <div class="relative aspect-[4/5] rounded-[3rem] overflow-hidden border border-white/5 shadow-2xl">
            <Image 
              src={profile?.image_url || fotoJeison} 
              alt="Jeison Molina" 
              width={500}
              height={625}
              loading="eager"
              class="w-full h-full object-cover grayscale brightness-90 group-hover:grayscale-0 group-hover:brightness-105 transition-all duration-700 scale-105 group-hover:scale-100"
            />
            
            <!-- Dynamic Card -->
            <div class="absolute bottom-6 left-6 right-6 p-6 glass rounded-3xl border-white/10 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-primary/20 rounded-2xl flex items-center justify-center text-primary">
                  <Terminal size={24} />
                </div>
                <div>
                  <h3 class="text-text-main font-bold">Full Stack Developer</h3>
                  <p class="text-xs text-text-muted font-medium">Core Architect & Performance Specialist</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating Badges -->
          <div class="absolute -top-6 -right-6 p-4 glass rounded-2xl border-white/10 animate-float shadow-xl">
             <div class="flex items-center gap-3">
               <div class="w-8 h-8 bg-green-500/20 rounded-full flex items-center justify-center text-green-500">
                 <Zap size={16} fill="currentColor" />
               </div>
               <span class="text-xs font-bold">99+ Performance</span>
             </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Extra animations if needed */
</style>
