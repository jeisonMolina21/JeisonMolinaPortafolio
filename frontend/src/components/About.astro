---
import { User, Zap, Sparkles, Database, Terminal, Cpu } from 'lucide-react';
import { getSkillIcon } from '../utils/iconMapper';

interface Props {
  profile: any;
  groupedSkills: any;
}

const { profile, groupedSkills } = Astro.props;
---

<section id="about" class="section-padding bg-white dark:bg-midnight transition-colors duration-500 relative overflow-hidden">
  <div class="container-custom relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-20 items-center">
      
      <!-- Bio Column -->
      <div class="lg:col-span-6 space-y-10">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary/10 rounded-lg mb-6">
            <User size={14} class="text-primary" />
            <span class="text-[10px] font-black uppercase tracking-widest text-primary">Arquitecto de Soluciones</span>
          </div>
          <h2 class="text-5xl md:text-6xl font-black text-text-main leading-tight tracking-tighter">
            Resolviendo problemas complejos con <span class="text-primary italic">Código Eficiente</span>
          </h2>
        </div>

        <div class="space-y-6 text-lg text-text-dim leading-relaxed">
          {profile?.bio && profile.bio.split('\n\n').slice(0, 2).map((para: string) => (
            <p>{para}</p>
          ))}
        </div>

        <!-- Metrics Grid -->
        <div class="grid grid-cols-2 gap-6 pt-6">
          <div class="p-6 bg-bg-deep dark:bg-white/5 rounded-3xl border border-primary/10">
            <p class="text-4xl font-black text-primary mb-2">40h → 5m</p>
            <p class="text-xs font-bold text-text-muted uppercase tracking-widest">Automatización Extrema</p>
          </div>
          <div class="p-6 bg-bg-deep dark:bg-white/5 rounded-3xl border border-primary/10">
            <p class="text-4xl font-black text-primary mb-2">+35%</p>
            <p class="text-xs font-bold text-text-muted uppercase tracking-widest">Eficiencia Operativa</p>
          </div>
        </div>
      </div>

      <!-- Skills Grid Column -->
      <div class="lg:col-span-6">
        <div class="glass p-10 md:p-14 rounded-[3rem] border border-primary/10 shadow-xl relative">
          <div class="absolute -top-6 -right-6 w-24 h-24 bg-primary/10 blur-3xl rounded-full"></div>
          
          <h3 class="text-xl font-bold text-text-main mb-10 flex items-center gap-3">
            <Terminal size={20} class="text-primary" />
            Stack Especializado
          </h3>

          <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
            {Object.entries(groupedSkills).map(([category, catSkills]: [string, any]) => (
              catSkills.slice(0, 3).map((skill: any) => (
                <div class="flex flex-col items-center gap-3 p-4 bg-white/50 dark:bg-black/20 rounded-2xl border border-black/5 dark:border-white/5 hover:border-primary/30 transition-all group">
                  <div class="w-12 h-12 flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                    {category === 'Backend & Data' && <Database size={24} />}
                    {category === 'Frontend' && <Sparkles size={24} />}
                    {category === 'DevOps & Cloud' && <Cpu size={24} />}
                  </div>
                  <span class="text-xs font-bold text-text-dim group-hover:text-primary transition-colors">{skill.name}</span>
                </div>
              ))
            ))}
          </div>
          
          <div class="mt-10 pt-10 border-t border-primary/10 flex items-center gap-4">
            <div class="flex -space-x-3">
              {[1, 2, 3, 4].map(i => (
                <div class="w-8 h-8 rounded-full bg-primary/20 border-2 border-bg-surface flex items-center justify-center text-[10px] font-bold text-primary">
                  {i}
                </div>
              ))}
            </div>
            <p class="text-xs font-medium text-text-muted italic">Manejando las herramientas líderes del mercado.</p>
          </div>
        </div>
      </div>

    </div>
  </div>
    </div>
  </div>
</section>
