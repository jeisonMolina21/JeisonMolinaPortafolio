---
import { Github, Linkedin, Twitter, Mail, ArrowUpCircle } from 'lucide-react';

const currentYear = new Date().getFullYear();
---

<footer class="footer-root">
  <div class="footer-glow"></div>

  <div class="container-custom relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-16 md:gap-8 items-start mb-20">
      <div class="md:col-span-5 space-y-8">
        <a href="#" class="footer-logo">
          PORT<span class="wine-gradient italic">AFOLIO</span>
        </a>
        <p class="footer-bio">
          ¿Tienes un proceso de <span class="text-white font-black italic">40h</span> que quieres reducir a <span class="text-primary-bright font-black">5min</span>?
        </p>
        <div class="flex flex-col gap-4">
          <a href="mailto:andreyyeisonmg@gmail.com" class="text-white/60 hover:text-white transition-colors">andreyyeisonmg@gmail.com</a>
          <a href="https://calendly.com/jeisonmolina/15min" target="_blank" class="text-primary-bright font-black hover:underline">Agenda 15 min conmigo →</a>
        </div>
        <div class="flex gap-4 pt-4">
          {[
            { icon: <Github size={20} />, href: "https://github.com/jeisonMolina21" },
            { icon: <Linkedin size={20} />, href: "https://linkedin.com/in/jeisonmolina" },
            { icon: <Mail size={20} />, href: "mailto:andreyyeisonmg@gmail.com" }
          ].map(social => (
            <a 
              href={social.href} 
              target="_blank" 
              class="footer-social-link"
            >
              {social.icon}
            </a>
          ))}
        </div>
      </div>

      <div class="md:col-span-7 grid grid-cols-2 md:grid-cols-3 gap-12">
        <div class="space-y-6">
          <h4 class="footer-nav-title">Navigation</h4>
          <ul class="space-y-4">
            {['Hero', 'Experience', 'Projects', 'Skills'].map(item => (
              <li>
                <a href={`#${item.toLowerCase()}`} class="footer-nav-link">{item}</a>
              </li>
            ))}
            <li>
              <a href="/cv-jeison-molina.pdf" class="footer-nav-link font-black text-primary-bright">Download CV</a>
            </li>
          </ul>
        </div>
        
        <div class="space-y-6">
          <h4 class="footer-nav-title">Legal</h4>
          <ul class="space-y-4">
            {['Privacy', 'Terms', 'Security'].map(item => (
              <li>
                <a href="#" class="footer-nav-link">{item}</a>
              </li>
            ))}
          </ul>
        </div>

        <div class="col-span-2 md:col-span-1 space-y-6">
          <button 
            onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
            class="footer-back-to-top"
          >
            Back to Top
            <ArrowUpCircle size={20} className="group-hover:-translate-y-1 transition-transform" />
          </button>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-copy">
        © {currentYear} Molina Jam. All systems operational.
      </div>
      <div class="footer-status">
        <span class="status-dot"></span>
        Bogotá Hub Protocol
      </div>
    </div>
  </div>
</footer>
