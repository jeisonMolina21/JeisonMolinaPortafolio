---
---
<section class="py-20 bg-bg-deep relative overflow-hidden">
  <div class="container mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      
      <!-- Metric 1 -->
      <div class="glass p-10 rounded-[3rem] border border-white/5 text-center group hover:border-primary/30 transition-all">
        <div class="text-7xl font-black text-white mb-4 tracking-tighter group-hover:text-primary transition-colors">
          +50k
          <span class="text-2xl text-primary block mt-2">/día</span>
        </div>
        <p class="text-text-muted font-bold uppercase tracking-widest text-xs">Registros procesados con <br/> <span class="text-text-main">Pandas & MySQL</span></p>
      </div>

      <!-- Metric 2 -->
      <div class="glass p-10 rounded-[3rem] border border-white/5 text-center group hover:border-primary/30 transition-all">
        <div class="text-7xl font-black text-white mb-4 tracking-tighter group-hover:text-primary transition-colors">
          6
          <span class="text-2xl text-primary block mt-2">APIs</span>
        </div>
        <p class="text-text-muted font-bold uppercase tracking-widest text-xs">Sistemas integrados con <br/> <span class="text-text-main">OAuth2 & Graph API</span></p>
      </div>

      <!-- Metric 3 -->
      <div class="glass p-10 rounded-[3rem] border border-white/5 text-center group hover:border-primary/30 transition-all">
        <div class="text-7xl font-black text-white mb-4 tracking-tighter group-hover:text-primary transition-colors">
          99.8%
        </div>
        <p class="text-text-muted font-bold uppercase tracking-widest text-xs">Integridad de datos <br/> <span class="text-text-main">en producción</span></p>
      </div>

      <!-- Metric 4 -->
      <div class="glass p-10 rounded-[3rem] border border-white/5 text-center group hover:border-primary/30 transition-all">
        <div class="text-7xl font-black text-white mb-4 tracking-tighter group-hover:text-primary transition-colors">
          98/100
        </div>
        <p class="text-text-muted font-bold uppercase tracking-widest text-xs">Lighthouse Score <br/> <span class="text-text-main">Astro + Next.js</span></p>
      </div>

    </div>
  </div>
  
  <!-- Decorative background element -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary/5 rounded-full blur-[120px] -z-10"></div>
</section>
