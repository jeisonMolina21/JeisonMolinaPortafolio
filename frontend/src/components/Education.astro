---
import { GraduationCap, Calendar, BookOpen } from 'lucide-react';

interface Props {
  education: any[];
}

const { education } = Astro.props;
const items = education || [];
---

<section id="education" class="section-padding bg-midnight/50">
  <div class="container-custom relative z-10">
    <div class="text-center mb-24">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 glass rounded-full border-primary/20 mb-6">
        <GraduationCap size={12} class="text-primary" />
        <span class="text-[10px] font-bold uppercase tracking-widest text-primary italic">Formación</span>
      </div>
      <h2 class="text-5xl md:text-7xl lg:text-8xl font-display font-black text-text-main tracking-tighter">
        Educación & <span class="text-primary italic">Certificaciones</span>
      </h2>
    </div>

    <div class="relative">
      <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-primary/50 via-primary/20 to-transparent md:-translate-x-1/2"></div>

      <div class="space-y-16">
        {items.map((edu, index) => (
          <div class={`relative flex flex-col md:flex-row items-center gap-8 ${index % 2 !== 0 ? 'md:flex-row-reverse' : ''}`}>
            <div class="absolute left-0 md:left-1/2 w-4 h-4 rounded-full bg-primary-bright border-4 border-midnight shadow-[0_0_20px_rgba(220,38,38,0.5)] z-20 md:-translate-x-1/2"></div>

            <div class="w-full md:w-[45%]">
              <div class="glass p-8 md:p-10 rounded-[2.5rem] border-white/5 hover:border-primary/30 transition-all duration-500">
                <div class="flex items-center gap-2 text-primary-bright font-black text-[10px] uppercase tracking-widest mb-6">
                  <Calendar size={14} />
                  {edu.period}
                </div>

                <h3 class="text-2xl md:text-3xl font-black text-text-main mb-2">
                  {edu.degree}
                </h3>
                
                <div class="flex items-center gap-4 text-text-dim text-sm font-medium mb-6">
                  <GraduationCap size={14} class="text-primary" />
                  {edu.institution}
                </div>

                {edu.description && (
                  <div class="flex gap-3 text-text-dim text-lg leading-relaxed font-medium">
                    <BookOpen size={20} class="shrink-0 mt-1 text-primary/40" />
                    <p>{edu.description}</p>
                  </div>
                )}
              </div>
            </div>

            <div class="hidden md:block w-[45%]"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
